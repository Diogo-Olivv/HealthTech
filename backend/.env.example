PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Autenticação (JWT)
# Em produção use um valor longo e aleatório vindo do Secret Manager
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1d

# Banco de Dados local (Docker Compose --> somente desenvolvimento)
# Rode: docker-compose up -d na raiz do repositório
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=healthtech

# Google Cloud SQL (Cloud Run --> produção)
# APENAS EM PRODUÇÃO --> preencha no Cloud Run:
#   Settings > Variables & Secrets
#
# Formato: PROJECT_ID:REGION:INSTANCE_NAME
# Exemplo: healthtech-proj:us-central1:healthtech-db
INSTANCE_CONNECTION_NAME=

# DB_USER, DB_PASSWORD e DB_NAME acima são reutilizados --> TROQUE os valores em produção
